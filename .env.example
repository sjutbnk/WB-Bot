# Telegram Bot Tokens
BOT_TOKEN_ADV=your_advertising_bot_token_here
BOT_TOKEN_SUPPLY=your_supply_bot_token_here

# Wildberries API Tokens
WB_API_TOKEN=your_wb_api_token_here
# В некоторых кабинетах API продвижения идет отдельным токеном, в некоторых — общим.
WB_ADV_TOKEN=your_wb_promotion_api_token_here

# Gemini API Key (для генерации SEO-описаний и ТЗ)
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=postgres_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maria_auto_db

# Список ID пользователей Telegram через запятую, у кого есть доступ к боту
ADMIN_IDS=123456789,987654321
